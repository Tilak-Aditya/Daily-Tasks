const track = document.querySelector('.slider-track');
const slides = document.querySelectorAll('.slide');
const nextBtn = document.getElementById('nextBtn');
const prevBtn = document.getElementById('prevBtn');
const dots = document.querySelectorAll('.dot');



let currentIndex = 0;

function updateSlider(index) {
    // Move the track
    track.style.transform = `translateX(-${index * 100}%)`;
    
    // Update Dots
    dots.forEach(dot => dot.classList.remove('active'));
    dots[index].classList.add('active');
    
    currentIndex = index;
}

nextBtn.addEventListener('click', () => {
    let index = (currentIndex + 1 === slides.length) ? 0 : currentIndex + 1;
    updateSlider(index);
});

prevBtn.addEventListener('click', () => {
    let index = (currentIndex === 0) ? slides.length - 1 : currentIndex - 1;
    updateSlider(index);
});

// Auto-play (Optional)
setInterval(() => {
    nextBtn.click();
}, 3000);



// adding toggler button
  const tabs = document.querySelectorAll(".tab");
  const slider = document.querySelector(".slider");
  const sections = document.querySelectorAll(".section");

  tabs.forEach((tab, index) => {
    tab.addEventListener("click", () => {

      // Remove active class from all
      tabs.forEach(t => t.classList.remove("active"));
      sections.forEach(sec => sec.classList.remove("active-section"));

      // Add active to clicked
      tab.classList.add("active");
      document.getElementById(tab.dataset.target)
        .classList.add("active-section");

      // Move slider
      slider.style.transform = `translateX(${index * 100}%)`;
    });
  });

//functionality for products
function createProduct(eachProduct){
     const cardText=eachProduct.productName;
  const cardImage=eachProduct.image;


  const RecProductCard=document.createElement("div");
  RecProductCard.style.backgroundImage = `url(${cardImage})`;

  const wishlistIcon=document.createElement("i");
  wishlistIcon.className="fa-regular fa-heart wishIcon";

  wishlistIcon.addEventListener("click", () => {
     
    const isLiked = wishlistIcon.classList.contains("fa-regular");


    // Switch between regular and solid
    wishlistIcon.classList.toggle("fa-regular");
    wishlistIcon.classList.toggle("fa-solid");

    // Add red color + small scale
    wishlistIcon.classList.toggle("liked");

    if (isLiked) {
        // Product added to wishlist
        console.log(" Added to Wishlist:");
        console.log({
            id: eachProduct._id,
            name: eachProduct.productName,
            price: eachProduct.price,
            image: eachProduct.image
        });
        wishListProducts.push({
            id: eachProduct._id,
            name: eachProduct.productName,
            price: eachProduct.price,
            image: eachProduct.image
        });
        console.log(wishListProducts);
    } else {
        // Product removed from wishlist
          wishListProducts = wishListProducts.filter(
            item => item.id !== eachProduct._id
        );
        console.log(" Removed from Wishlist:", eachProduct.productName);
    }
   localStorage.setItem("wishlist", JSON.stringify(wishListProducts));

});

  RecProductCard.appendChild(wishlistIcon);

  const divCon=document.createElement("div");
  divCon.classList.add("divCon");
 

  const ProductDetails=document.createElement("div");
  ProductDetails.classList.add("productionDetails");
  const cardData=document.createElement("h1");
  cardData.classList.add("productName");
  cardData.textContent=cardText;
  divCon.appendChild(cardData);

 
  

  const price = document.createElement("p");
  price.textContent = `$${eachProduct.price}`;
  ProductDetails.appendChild(price);

  const button = document.createElement("button");
  const span =document.createElement("span");
  span.classList.add("button-content");
  span.textContent = "Add to Cart";  
  button.appendChild(span);
  button.classList.add("addTocartButton");
  button.addEventListener("click", () => {
  console.log("Added:", eachProduct.productName);
});
   ProductDetails.appendChild(button);
   
   divCon.appendChild(ProductDetails);
    RecProductCard.appendChild(divCon);
  RecProductCard.classList.add("productCard");

  return RecProductCard;

}



